# Copy to .env and fill in. All variables are prefixed with ZENCODED_.

# --- GitHub OAuth (operator login) ---
ZENCODED_GITHUB_CLIENT_ID=
ZENCODED_GITHUB_CLIENT_SECRET=
# Comma-separated GitHub usernames allowed to trigger jobs (deny-by-default).
ZENCODED_OAUTH_ALLOWLIST=your-github-login

# --- Web session ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ZENCODED_SESSION_SECRET=
# Public URL of the deployed service; OAuth callback is <base_url>/auth/callback
ZENCODED_BASE_URL=https://zencoded.example.com
# Set false ONLY for local http development.
ZENCODED_SECURE_COOKIES=true

# --- Git publishing (deploy key scoped to THIS repo only) ---
ZENCODED_REPO_DIR=/srv/zencoded
ZENCODED_GIT_BRANCH=main
ZENCODED_DEPLOY_KEY_PATH=/run/secrets/zencoded_deploy_key
ZENCODED_KNOWN_HOSTS_PATH=/srv/zencoded/.ssh/known_hosts
ZENCODED_GIT_AUTHOR_NAME=zencoded-bot
ZENCODED_GIT_AUTHOR_EMAIL=zencoded-bot@users.noreply.github.com
# Set false to encode + write to data/ without committing (dev).
ZENCODED_PUBLISH_ENABLED=true

# --- Download / encoding ---
ZENCODED_MAX_DOWNLOAD_BYTES=104857600
ZENCODED_DOWNLOAD_TIMEOUT=30
ZENCODED_DEFAULT_COMPRESS=never
